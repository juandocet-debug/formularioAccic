APP_NAME="Formulario ASIC"
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
DATABASE_PATH=./data/formulario_asic.sqlite3
# Railway PostgreSQL inyecta DATABASE_URL automaticamente cuando se referencia desde el servicio backend.
# DATABASE_URL=postgresql://user:password@host:port/database
JWT_SECRET=change-this-secret-before-deploy
JWT_EXPIRES_MINUTES=480
ADMIN_USERNAME=superadmin
ADMIN_PASSWORD=change-this-password
CORS_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app
